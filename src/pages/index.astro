---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Level 10">
  <section class="relative w-full h-screen flex flex-col items-center justify-center bg-[var(--color-bg)] overflow-hidden pb-24">
    <!-- Text container wrapper for all hero texts -->
    <div class="relative h-32 md:h-44 lg:h-56 w-screen">
      <!-- TXP text (visible by default) -->
      <div id="heroTextTXP" class="absolute inset-0 transition-all duration-500 ease-out">
        <p class="absolute top-0 left-1/2 -translate-x-1/2 text-lg md:text-2xl font-light tracking-wide whitespace-nowrap">
          Hallo, ich bin
        </p>
        <h1 class="absolute top-7 md:top-10 lg:top-12 left-1/2 -translate-x-1/2 text-5xl md:text-7xl lg:text-9xl font-bold tracking-tight whitespace-nowrap">
          TXP
        </h1>
      </div>

      <!-- TXP final text (hidden initially) -->
      <div id="heroTextFinal" class="absolute inset-0 opacity-0 transition-all duration-500 ease-out pointer-events-none">
        <p class="absolute top-0 left-1/2 -translate-x-1/2 text-lg md:text-2xl font-light tracking-wide whitespace-nowrap">
          Ich habe gesehen, dass du fleißig die Level bei AI Bytes gespielt hast
        </p>
        <h1 class="absolute top-7 md:top-10 lg:top-12 left-1/2 -translate-x-1/2 text-3xl md:text-5xl lg:text-6xl font-bold tracking-tight whitespace-nowrap">
          Schön dich kennenzulernen!
        </h1>
      </div>

      <!-- TXP welcome text (hidden initially) -->
      <div id="heroTextWelcome" class="absolute inset-0 opacity-0 transition-all duration-500 ease-out pointer-events-none">
        <p class="absolute top-0 left-1/2 -translate-x-1/2 text-lg md:text-2xl font-light tracking-wide whitespace-nowrap">
          Willkommen im geheimen Level von AI Bytes
        </p>
        <h1 class="absolute top-7 md:top-10 lg:top-12 left-1/2 -translate-x-1/2 text-3xl md:text-5xl lg:text-6xl font-bold tracking-tight whitespace-nowrap">
          Das schaffen nur die wenigsten
        </h1>
      </div>

      <!-- TXP thanks text (hidden initially) -->
      <div id="heroTextThanks" class="absolute inset-0 opacity-0 transition-all duration-500 ease-out pointer-events-none">
        <p class="absolute top-0 left-1/2 -translate-x-1/2 text-lg md:text-2xl font-light tracking-wide whitespace-nowrap">
          Vielen Dank für das fleißige Punkte sammeln
        </p>
        <h1 class="absolute top-7 md:top-10 lg:top-12 left-1/2 -translate-x-1/2 text-3xl md:text-5xl lg:text-6xl font-bold tracking-tight whitespace-nowrap">
          Ich bin sehr beeindruckt
        </h1>
      </div>

      <!-- TXP runner text (hidden initially) -->
      <div id="heroTextRunner" class="absolute inset-0 opacity-0 transition-all duration-500 ease-out pointer-events-none">
        <p class="absolute top-0 left-1/2 -translate-x-1/2 text-lg md:text-2xl font-light tracking-wide whitespace-nowrap">
          Ich habe einen Termin
        </p>
        <h1 class="absolute top-7 md:top-10 lg:top-12 left-1/2 -translate-x-1/2 text-3xl md:text-5xl lg:text-6xl font-bold tracking-tight whitespace-nowrap">
          Hilf mir den Ort zu erreichen
        </h1>
      </div>

      <!-- TXP jump hint text (hidden initially) -->
      <div id="heroTextJump" class="absolute inset-0 opacity-0 transition-all duration-500 ease-out pointer-events-none">
        <p class="absolute top-0 left-1/2 -translate-x-1/2 text-lg md:text-2xl font-light tracking-wide whitespace-nowrap">
          Springe mit der
        </p>
        <h1 class="absolute top-7 md:top-10 lg:top-12 left-1/2 -translate-x-1/2 text-3xl md:text-5xl lg:text-6xl font-bold tracking-tight whitespace-nowrap">
          Leertaste
        </h1>
      </div>

      <!-- TXP double jump hint text (hidden initially) -->
      <div id="heroTextDoubleJump" class="absolute inset-0 opacity-0 transition-all duration-500 ease-out pointer-events-none">
        <p class="absolute top-0 left-1/2 -translate-x-1/2 text-lg md:text-2xl font-light tracking-wide whitespace-nowrap">
          Drücke erneut die Leertaste für einen
        </p>
        <h1 class="absolute top-7 md:top-10 lg:top-12 left-1/2 -translate-x-1/2 text-3xl md:text-5xl lg:text-6xl font-bold tracking-tight whitespace-nowrap">
          Doppelsprung
        </h1>
      </div>

      <!-- TXP score text (hidden initially) -->
      <div id="heroTextScore" class="absolute inset-0 opacity-0 transition-all duration-500 ease-out pointer-events-none">
        <p class="absolute top-0 left-1/2 -translate-x-1/2 text-lg md:text-2xl font-light tracking-wide whitespace-nowrap">
          Deine Punktzahl
        </p>
        <h1 id="scoreDisplay" class="absolute top-7 md:top-10 lg:top-12 left-1/2 -translate-x-1/2 text-3xl md:text-5xl lg:text-6xl font-bold tracking-tight whitespace-nowrap">
          0001
        </h1>
      </div>
    </div>

    <!-- TXP Platform (fixed position under title) -->
    <div id="txpPlatformContainer" class="absolute left-1/2 -translate-x-1/2 pointer-events-none overflow-visible" style="top: calc(50% + 18rem);">
      <div id="txpPlatform" class="w-28 md:w-36 h-2 bg-[var(--color-fg)] transform scale-x-100 transition-transform duration-300 ease-out origin-center"></div>
      <!-- Runner ground (hidden initially) -->
      <div id="txpRunnerGround" class="absolute top-0 left-0 h-2 bg-[var(--color-fg)] opacity-0" style="width: 300vw; transform: translateX(-50vw);"></div>
    </div>

    <!-- TXP Character (already on platform) -->
    <div id="txpCharacter" class="fixed pointer-events-auto cursor-pointer z-[60]" style="width: 90px; height: 90px;">
      <img id="txpSprite" src="" alt="" class="txp-sprite w-full h-full object-contain transition-transform duration-300" />
      <!-- Click me hint -->
      <span id="txpClickHint" class="absolute left-full top-1/2 -translate-y-1/2 ml-2 text-sm font-medium whitespace-nowrap opacity-0 transition-opacity duration-300">klick mich an</span>
    </div>

    <!-- Death Screen Overlay -->
    <div id="txpDeathScreen" class="fixed inset-0 z-[70] flex flex-col items-center justify-center opacity-0 pointer-events-none transition-opacity duration-500" style="background-color: var(--color-bg);">
      <p class="text-lg md:text-2xl font-light tracking-wide">Deine Punktzahl</p>
      <h2 id="deathScoreDisplay" class="text-5xl md:text-7xl lg:text-9xl font-bold tracking-tight mt-2 mb-6">0000</h2>
      <p id="txpHighscoreDisplay" class="text-sm font-light tracking-widest uppercase mb-12 opacity-50">Highscore &nbsp; 0000</p>
      <p class="text-sm font-light tracking-widest uppercase opacity-50">Leertaste zum Neustarten</p>
      <div class="mt-20 flex flex-col items-center gap-1 opacity-40">
        <p class="text-xs font-light tracking-widest uppercase">Teile uns deinen Highscore</p>
        <p class="text-xs font-light tracking-wide">Projektleiter: david.bokop@mercedes-benz.com</p>
        <p class="text-xs font-light tracking-wide">Webdesigner: til.sander@mercedes-benz.com</p>
      </div>
    </div>

    <!-- Pause Screen Overlay -->
    <div id="txpPauseScreen" class="fixed inset-0 z-[70] flex flex-col items-center justify-center opacity-0 pointer-events-none transition-opacity duration-300" style="background-color: var(--color-bg);">
      <h2 class="text-5xl md:text-7xl lg:text-9xl font-bold tracking-tight mb-8">Pausiert</h2>
      <div class="flex flex-col gap-3 text-center">
        <p class="text-sm font-light tracking-widest uppercase opacity-70">ESC zum Fortsetzen</p>
        <p class="text-sm font-light tracking-widest uppercase opacity-70">Leertaste zum Neustarten</p>
      </div>
    </div>
  </section>

  <script>
    interface AnimationConfig {
      frames: number;
      fps: number;
      path: string;
    }

    type AnimationName = "jump" | "idle" | "walk" | "talk";

    const ANIMATIONS: Record<AnimationName, AnimationConfig> = {
      jump: { frames: 120, fps: 15, path: "/animations/txp/jump/TXP%20Sprung_" },
      idle: { frames: 24, fps: 24, path: "/animations/txp/idle/TXP%20Stand%20Pose_" },
      walk: { frames: 24, fps: 24, path: "/animations/txp/walk/TXP%20Lauf%20Loop_" },
      talk: { frames: 24, fps: 24, path: "/animations/txp/talk/TXP_Talk%20Pose_" },
    };

    const ENEMY_WALK = {
      frames: 12,
      fps: 24,
      path: "/animations/enemy1/walk/AI%20Gegner_FPS%2012",
    };

    const ENEMY2_JUMP = {
      frames: 24,
      fps: 36,
      path: "/animations/enemy2/Gegner%20Loop_",
    };

    const ENEMY3_FLY = {
      frames: 9,
      fps: 10,
      path: "/animations/enemy3/frame_",
      darkPath: "/animations/enemy3/darkmode/frame_",
      suffix: "_delay-0.1s.png",
    };

    type EnemyType = "walk" | "jump" | "fly";

    interface EnemyInstance {
      element: HTMLDivElement;
      sprite: HTMLImageElement;
      x: number;
      currentFrame: number;
      lastFrameTime: number;
      type: EnemyType;
      jumpOffset: number;
      lastJumpTime: number;
      speed: number;
      dying: boolean;
      baseY: number;
      hitbox: { x: number; y: number; w: number; h: number };
      floatAmplitude: number;
      points: number;
    }

    function padFrame(num: number): string {
      return num.toString().padStart(5, "0");
    }

    function preloadAnimation(anim: AnimationName): Promise<HTMLImageElement[]> {
      const config = ANIMATIONS[anim];
      const images: HTMLImageElement[] = [];
      const promises: Promise<void>[] = [];

      for (let i = 0; i < config.frames; i++) {
        const img = new Image();
        const promise = new Promise<void>((resolve) => {
          img.onload = () => resolve();
          img.onerror = () => resolve();
        });
        img.src = `${config.path}${padFrame(i)}.png`;
        images.push(img);
        promises.push(promise);
      }

      return Promise.all(promises).then(() => images);
    }

    function preloadEnemyAnimation(): Promise<HTMLImageElement[]> {
      const images: HTMLImageElement[] = [];
      const promises: Promise<void>[] = [];
      for (let i = 0; i < ENEMY_WALK.frames; i++) {
        const img = new Image();
        const promise = new Promise<void>((resolve) => {
          img.onload = () => resolve();
          img.onerror = () => resolve();
        });
        img.src = `${ENEMY_WALK.path}${padFrame(i)}.png`;
        images.push(img);
        promises.push(promise);
      }
      return Promise.all(promises).then(() => images);
    }

    function preloadEnemy2Animation(): Promise<HTMLImageElement[]> {
      const images: HTMLImageElement[] = [];
      const promises: Promise<void>[] = [];
      for (let i = 0; i < ENEMY2_JUMP.frames; i++) {
        const img = new Image();
        const promise = new Promise<void>((resolve) => {
          img.onload = () => resolve();
          img.onerror = () => resolve();
        });
        img.src = `${ENEMY2_JUMP.path}${padFrame(i)}.png`;
        images.push(img);
        promises.push(promise);
      }
      return Promise.all(promises).then(() => images);
    }

    function preloadEnemy3Animation(): Promise<HTMLImageElement[]> {
      const images: HTMLImageElement[] = [];
      const promises: Promise<void>[] = [];
      for (let i = 0; i < ENEMY3_FLY.frames; i++) {
        const img = new Image();
        const promise = new Promise<void>((resolve) => {
          img.onload = () => resolve();
          img.onerror = () => resolve();
        });
        img.src = `${ENEMY3_FLY.path}${i}${ENEMY3_FLY.suffix}`;
        images.push(img);
        promises.push(promise);
      }
      return Promise.all(promises).then(() => images);
    }

    function preloadEnemy3DarkAnimation(): Promise<HTMLImageElement[]> {
      const images: HTMLImageElement[] = [];
      const promises: Promise<void>[] = [];
      for (let i = 0; i < ENEMY3_FLY.frames; i++) {
        const img = new Image();
        const promise = new Promise<void>((resolve) => {
          img.onload = () => resolve();
          img.onerror = () => resolve();
        });
        img.src = `${ENEMY3_FLY.darkPath}${i}${ENEMY3_FLY.suffix}`;
        images.push(img);
        promises.push(promise);
      }
      return Promise.all(promises).then(() => images);
    }

    class TXPAnimator {
      private sprite: HTMLImageElement;
      private character: HTMLElement;
      private platform: HTMLElement;
      private platformContainer: HTMLElement;
      private heroTextTXP: HTMLElement;
      private heroTextFinal: HTMLElement;
      private heroTextWelcome: HTMLElement;
      private heroTextThanks: HTMLElement;
      private heroTextRunner: HTMLElement;
      private heroTextJump: HTMLElement;
      private heroTextDoubleJump: HTMLElement;
      private heroTextScore: HTMLElement;
      private scoreDisplay: HTMLElement;
      private clickHint: HTMLElement;
      private runnerGround: HTMLElement;
      private currentFrames: HTMLImageElement[] = [];
      private currentFrame = 0;
      private animationId: number | null = null;
      private lastFrameTime = 0;
      private fps = 24;
      private isActive = true;
      private isLanded = true;
      private textState = 1;
      private cachedAnimations: Map<AnimationName, HTMLImageElement[]> = new Map();
      private hintTimeout: ReturnType<typeof setTimeout> | null = null;
      private isShowingHint = false;
      private isRunning = false;
      private isJumping = false;
      private runnerAnimationId: number | null = null;
      private groundOffset = 0;
      private totalLeftExtension = 0;
      private scaleAfterPhase1 = 0;
      private jumpHintTimeout: ReturnType<typeof setTimeout> | null = null;
      private boundHandleKeydown: (e: KeyboardEvent) => void;
      private score = 0;
      private scoreAccum = 0;
      private scoreLoopId: number | null = null;
      private hasJumpedOnce = false;
      private isTutorialPeakFreeze = false;
      private enemies: EnemyInstance[] = [];
      private enemyFrames: HTMLImageElement[] = [];
      private enemy2Frames: HTMLImageElement[] = [];
      private enemy3Frames: HTMLImageElement[] = [];
      private enemy3DarkFrames: HTMLImageElement[] = [];
      private distanceSinceLastSpawn = 0;
      private nextSpawnGap = 0;
      private gameLoopId: number | null = null;
      private showHitboxes = false;
      private isDead = false;
      private isPaused = false;
      private highscore = 0;
      private deathScreen!: HTMLElement;
      private deathScoreDisplay!: HTMLElement;
      private highscoreDisplay!: HTMLElement;
      private pauseScreen!: HTMLElement;
      private txpHitbox = { x: 20, y: 10, w: 50, h: 76 };
      private enemyHitbox = { x: 10, y: 5, w: 65, h: 80 };
      private txpHitboxEl: HTMLDivElement | null = null;
      private enemySpeed = 250;
      private platformStartWidth = 0;
      private baseEnemySpeed = 250;
      private basePlatformScrollSpeed = 80;
      private baseWalkFPS = 24;
      private currentJumpProgress = 0;
      private currentOffsetY = 0;
      private jumpTotalPausedTime = 0;
      private jumpStartTime = 0;
      private jumpDelayDuration = 0;
      private jumpDurationWithoutDelay = 0;
      private isDoubleJumping = false;   // Arc läuft (Stomp oder Space)
      private hasUsedSpaceDoubleJump = false; // Space-Slot verbraucht
      private doubleJumpStartTime = 0;
      private doubleJumpDuration = 1400;
      private doubleJumpStartOffsetY = 0;
      private doubleJumpTotalPausedTime = 0;
      private boundHandleKeyup: (e: KeyboardEvent) => void;

      constructor() {
        this.sprite = document.getElementById("txpSprite") as HTMLImageElement;
        this.character = document.getElementById("txpCharacter") as HTMLElement;
        this.platform = document.getElementById("txpPlatform") as HTMLElement;
        this.platformContainer = document.getElementById("txpPlatformContainer") as HTMLElement;
        this.heroTextTXP = document.getElementById("heroTextTXP") as HTMLElement;
        this.heroTextFinal = document.getElementById("heroTextFinal") as HTMLElement;
        this.heroTextWelcome = document.getElementById("heroTextWelcome") as HTMLElement;
        this.heroTextThanks = document.getElementById("heroTextThanks") as HTMLElement;
        this.heroTextRunner = document.getElementById("heroTextRunner") as HTMLElement;
        this.heroTextJump = document.getElementById("heroTextJump") as HTMLElement;
        this.heroTextDoubleJump = document.getElementById("heroTextDoubleJump") as HTMLElement;
        this.heroTextScore = document.getElementById("heroTextScore") as HTMLElement;
        this.scoreDisplay = document.getElementById("scoreDisplay") as HTMLElement;
        this.clickHint = document.getElementById("txpClickHint") as HTMLElement;
        this.runnerGround = document.getElementById("txpRunnerGround") as HTMLElement;
        this.deathScreen = document.getElementById("txpDeathScreen") as HTMLElement;
        this.deathScoreDisplay = document.getElementById("deathScoreDisplay") as HTMLElement;
        this.highscoreDisplay = document.getElementById("txpHighscoreDisplay") as HTMLElement;
        this.pauseScreen = document.getElementById("txpPauseScreen") as HTMLElement;
        this.highscore = parseInt(localStorage.getItem("txpHighscore") ?? "0", 10);

        this.boundHandleKeydown = this.handleKeydown.bind(this);
        this.boundHandleKeyup = this.handleKeyup.bind(this);

        window.addEventListener("resize", () => {
          if (this.isActive && this.isLanded) {
            this.updatePosition();
          }
        });

        this.character.addEventListener("click", () => {
          if (!this.isActive) return;

          if (this.textState < 4) {
            this.hideHint();
            this.talk();
            this.startHintTimer();
          } else if (this.textState === 4 && !this.isRunning) {
            this.cancelHintTimer();
            this.hideHint();
            this.startRunnerMode();
          }
        });

        // Auto-activate: place TXP on platform immediately
        this.autoActivate();
      }

      private async autoActivate() {
        // Preload idle animation
        const idleFrames = await preloadAnimation("idle");
        this.cachedAnimations.set("idle", idleFrames);

        // Position character on platform
        this.updatePosition();

        // Set first idle frame and show character
        this.sprite.src = idleFrames[0].src;

        // Play idle animation
        this.playAnimation(idleFrames, 24, true);

        // Start hint timer
        this.startHintTimer();
      }

      private cancelHintTimer() {
        if (this.hintTimeout) {
          clearTimeout(this.hintTimeout);
          this.hintTimeout = null;
        }
      }

      private hideHint() {
        this.clickHint.style.opacity = "0";
        this.isShowingHint = false;
      }

      private async showClickHint() {
        if (!this.isActive || this.textState >= 5 || this.isShowingHint) return;

        this.isShowingHint = true;
        this.clickHint.style.opacity = "1";
        this.playHintTalkAnimation();

        setTimeout(() => {
          if (this.isActive) {
            this.hideHint();
            this.startHintTimer();
          }
        }, 2000);
      }

      private async playHintTalkAnimation() {
        let talkFrames = this.cachedAnimations.get("talk");
        if (!talkFrames) {
          talkFrames = await preloadAnimation("talk");
          this.cachedAnimations.set("talk", talkFrames);
        }

        const startTime = performance.now();
        const duration = 2000;

        if (this.animationId) {
          cancelAnimationFrame(this.animationId);
        }

        this.currentFrames = talkFrames;
        this.currentFrame = 0;
        this.fps = 24;
        this.lastFrameTime = performance.now();

        const animateHint = (time: number) => {
          if (!this.isActive || !this.isShowingHint) {
            if (this.isActive) {
              this.returnToIdle();
            }
            return;
          }

          const elapsed = time - startTime;
          if (elapsed >= duration) {
            this.returnToIdle();
            return;
          }

          const frameElapsed = time - this.lastFrameTime;
          const frameInterval = 1000 / this.fps;

          if (frameElapsed >= frameInterval) {
            this.sprite.src = this.currentFrames[this.currentFrame].src;
            this.currentFrame = (this.currentFrame + 1) % this.currentFrames.length;
            this.lastFrameTime = time - (frameElapsed % frameInterval);
          }

          this.animationId = requestAnimationFrame(animateHint);
        };

        this.animationId = requestAnimationFrame(animateHint);
      }

      private async returnToIdle() {
        let idleFrames = this.cachedAnimations.get("idle");
        if (!idleFrames) {
          idleFrames = await preloadAnimation("idle");
          this.cachedAnimations.set("idle", idleFrames);
        }
        if (this.isActive) {
          this.playAnimation(idleFrames, 24, true);
        }
      }

      private startHintTimer() {
        this.cancelHintTimer();
        if (this.textState >= 5) return;

        this.hintTimeout = setTimeout(() => {
          this.showClickHint();
        }, 8000);
      }

      private async startRunnerMode() {
        this.isRunning = true;
        this.textState = 5;

        preloadEnemyAnimation().then(frames => {
          this.enemyFrames = frames;
        });
        preloadEnemy2Animation().then(frames => {
          this.enemy2Frames = frames;
        });
        preloadEnemy3Animation().then(frames => {
          this.enemy3Frames = frames;
        });
        preloadEnemy3DarkAnimation().then(frames => {
          this.enemy3DarkFrames = frames;
        });

        // Phase 1: Extend platform to the right
        const platformRect = this.platform.getBoundingClientRect();
        const startWidth = platformRect.width;
        this.platformStartWidth = startWidth;
        const targetWidthRight = startWidth + (window.innerWidth - platformRect.right);
        const extendSpeed = 400;

        this.platform.style.transformOrigin = "left center";

        await new Promise<void>((resolve) => {
          const startTime = performance.now();
          const duration = (targetWidthRight - startWidth) / extendSpeed * 1000;

          const animate = (currentTime: number) => {
            if (!this.isActive || !this.isRunning) {
              resolve();
              return;
            }

            const elapsed = currentTime - startTime;
            const progress = Math.min(elapsed / duration, 1);
            const currentWidth = startWidth + (targetWidthRight - startWidth) * progress;
            const scale = currentWidth / startWidth;

            this.platform.style.transform = `scaleX(${scale})`;

            if (progress < 1) {
              requestAnimationFrame(animate);
            } else {
              resolve();
            }
          };

          requestAnimationFrame(animate);
        });

        if (!this.isActive || !this.isRunning) return;

        await new Promise(resolve => setTimeout(resolve, 500));

        if (!this.isActive || !this.isRunning) return;

        // Phase 2: Extend platform to the left
        this.heroTextThanks.style.opacity = "0";
        this.heroTextThanks.style.transform = "translateY(-2rem)";
        setTimeout(() => {
          this.heroTextRunner.style.opacity = "1";
          this.heroTextRunner.style.transform = "translateY(0)";
        }, 150);

        let walkFrames = this.cachedAnimations.get("walk");
        if (!walkFrames) {
          walkFrames = await preloadAnimation("walk");
          this.cachedAnimations.set("walk", walkFrames);
        }
        this.playAnimation(walkFrames, this.baseWalkFPS, true);

        this.jumpHintTimeout = setTimeout(() => {
          if (!this.isActive || !this.isRunning) return;
          this.heroTextRunner.style.opacity = "0";
          this.heroTextRunner.style.transform = "translateY(-2rem)";
          setTimeout(() => {
            this.heroTextJump.style.opacity = "1";
            this.heroTextJump.style.transform = "translateY(0)";
          }, 150);
          window.addEventListener("keydown", this.boundHandleKeydown);
          window.addEventListener("keyup", this.boundHandleKeyup);
          this.distanceSinceLastSpawn = 0;
          this.nextSpawnGap = this.getNextSpawnGap();
          this.startGameLoop();
        }, 4000);

        this.scaleAfterPhase1 = targetWidthRight / startWidth;
        let lastTime = performance.now();
        this.totalLeftExtension = 0;

        const animateLeft = (time: number) => {
          if (!this.isActive || !this.isRunning || this.isPaused) return;

          const delta = (time - lastTime) / 1000;
          lastTime = time;

          const scrollSpeed = this.getCurrentPlatformScrollSpeed();
          this.totalLeftExtension += scrollSpeed * delta;

          const additionalScale = this.totalLeftExtension / startWidth;
          const totalScale = this.scaleAfterPhase1 + additionalScale;

          this.platform.style.transform = `translateX(-${this.totalLeftExtension}px) scaleX(${totalScale})`;

          this.runnerAnimationId = requestAnimationFrame(animateLeft);
        };

        this.runnerAnimationId = requestAnimationFrame(animateLeft);
      }

      private handleKeydown(e: KeyboardEvent) {
        if (e.code === "Space" && this.isRunning) {
          e.preventDefault();
          if (this.isDead) {
            this.restart();
          } else if (this.isPaused) {
            this.restart();
          } else if (!this.isJumping) {
            this.jump();
          } else if (this.isJumping && !this.hasUsedSpaceDoubleJump && !e.repeat) {
            this.isTutorialPeakFreeze = false;
            this.hasUsedSpaceDoubleJump = true;
            this.startDoubleJump();
          }
        }
        if (e.code === "Escape" && this.isRunning && this.hasJumpedOnce) {
          e.preventDefault();
          if (this.isPaused) {
            this.resume();
          } else if (!this.isDead) {
            this.pause();
          }
        }
        if (e.code === "KeyH" && this.isRunning) {
          this.toggleHitboxes();
        }
      }

      private handleKeyup(_e: KeyboardEvent) {
        // no-op: double jump doesn't require keyup tracking
      }

      private startDoubleJump() {
        this.isDoubleJumping = true;
        this.doubleJumpStartOffsetY = this.currentOffsetY;
        this.doubleJumpStartTime = performance.now();
        this.doubleJumpTotalPausedTime = 0;
        const jumpFrames = this.cachedAnimations.get("jump");
        if (jumpFrames) {
          this.playAnimation(jumpFrames.slice(0, 89), 50, false);
        }
      }

      private async jump() {
        if (this.isJumping || this.isPaused) return;
        this.isJumping = true;
        this.isDoubleJumping = false;
        this.hasUsedSpaceDoubleJump = false;
        this.jumpTotalPausedTime = 0;
        this.doubleJumpTotalPausedTime = 0;

        let jumpFrames = this.cachedAnimations.get("jump");
        if (!jumpFrames) {
          jumpFrames = await preloadAnimation("jump");
          this.cachedAnimations.set("jump", jumpFrames);
        }
        const shortJumpFrames = jumpFrames.slice(0, 89);

        const jumpHeight = 210;
        const totalFrames = 89;
        const startFrame = 5;
        const fps = 55;
        const jumpDuration = (totalFrames / fps) * 1000;
        const delayDuration = (startFrame / fps) * 1000;

        const startTime = performance.now();
        this.jumpStartTime = startTime;
        this.jumpDelayDuration = delayDuration;
        this.jumpDurationWithoutDelay = jumpDuration - delayDuration;
        let pauseStartTime = 0;
        let peakFreezeStartTime = 0;

        const animateJumpPosition = () => {
          if (!this.isJumping) {
            this.character.style.transform = "";
            return;
          }

          if (this.isPaused) {
            if (pauseStartTime === 0) pauseStartTime = performance.now();
            requestAnimationFrame(animateJumpPosition);
            return;
          } else if (pauseStartTime > 0) {
            const pausedDuration = performance.now() - pauseStartTime;
            this.jumpTotalPausedTime += pausedDuration;
            if (this.isDoubleJumping) this.doubleJumpTotalPausedTime += pausedDuration;
            pauseStartTime = 0;
          }

          if (this.isTutorialPeakFreeze) {
            if (peakFreezeStartTime === 0) peakFreezeStartTime = performance.now();
            requestAnimationFrame(animateJumpPosition);
            return;
          } else if (peakFreezeStartTime > 0) {
            this.jumpTotalPausedTime += performance.now() - peakFreezeStartTime;
            peakFreezeStartTime = 0;
          }

          const now = performance.now();

          if (this.isDoubleJumping) {
            const doubleElapsed = now - this.doubleJumpStartTime - this.doubleJumpTotalPausedTime;
            const doubleT = Math.min(doubleElapsed / this.doubleJumpDuration, 1);
            const offsetY = this.doubleJumpStartOffsetY * (1 - doubleT) - 190 * Math.sin(doubleT * Math.PI);
            this.currentOffsetY = offsetY;
            this.character.style.transform = `translateY(${offsetY}px)`;
            requestAnimationFrame(animateJumpPosition);
            return;
          }

          const elapsed = now - startTime - this.jumpTotalPausedTime;
          if (elapsed < delayDuration) {
            requestAnimationFrame(animateJumpPosition);
            return;
          }

          const jumpElapsed = elapsed - delayDuration;
          const jumpDurationWithoutDelay = jumpDuration - delayDuration;
          const progress = Math.min(jumpElapsed / jumpDurationWithoutDelay, 1);
          this.currentJumpProgress = progress;

          const offsetY = -jumpHeight * Math.sin(progress * Math.PI);
          this.currentOffsetY = offsetY;
          this.character.style.transform = `translateY(${offsetY}px)`;

          if (!this.hasJumpedOnce && !this.isTutorialPeakFreeze && progress >= 0.5) {
            this.isTutorialPeakFreeze = true;
            this.heroTextJump.style.opacity = "0";
            this.heroTextJump.style.transform = "translateY(-2rem)";
            setTimeout(() => {
              this.heroTextDoubleJump.style.opacity = "1";
              this.heroTextDoubleJump.style.transform = "translateY(0)";
            }, 150);
          }

          requestAnimationFrame(animateJumpPosition);
        };
        requestAnimationFrame(animateJumpPosition);

        await Promise.race([
          this.playAnimation(shortJumpFrames, 50, false),
          new Promise<void>((resolve) => {
            const checkDoubleJump = () => {
              if (this.isDoubleJumping) resolve();
              else if (!this.isJumping) resolve();
              else requestAnimationFrame(checkDoubleJump);
            };
            requestAnimationFrame(checkDoubleJump);
          }),
        ]);

        // Tutorial: if frozen at peak, wait for user to trigger double jump
        if (this.isTutorialPeakFreeze) {
          await new Promise<void>((resolve) => {
            const checkRelease = () => {
              if (!this.isTutorialPeakFreeze || !this.isJumping) resolve();
              else requestAnimationFrame(checkRelease);
            };
            requestAnimationFrame(checkRelease);
          });
        }

        if (this.isDoubleJumping && this.isJumping) {
          await new Promise<void>((resolve) => {
            const checkLanded = () => {
              if (!this.isJumping) { resolve(); return; }
              const elapsed = performance.now() - this.doubleJumpStartTime - this.doubleJumpTotalPausedTime;
              if (elapsed >= this.doubleJumpDuration) resolve();
              else requestAnimationFrame(checkLanded);
            };
            requestAnimationFrame(checkLanded);
          });

        }

        if (this.isRunning) {
          let walkFrames = this.cachedAnimations.get("walk");
          if (!walkFrames) {
            walkFrames = await preloadAnimation("walk");
            this.cachedAnimations.set("walk", walkFrames);
          }
          this.playAnimation(walkFrames, this.baseWalkFPS, true, 12);
        }

        this.isJumping = false;
        this.isDoubleJumping = false;

        if (!this.hasJumpedOnce) {
          this.hasJumpedOnce = true;
          this.distanceSinceLastSpawn = 0;
          this.nextSpawnGap = this.getNextSpawnGap();
          this.heroTextJump.style.opacity = "0";
          this.heroTextJump.style.transform = "translateY(-2rem)";
          this.heroTextDoubleJump.style.opacity = "0";
          this.heroTextDoubleJump.style.transform = "translateY(-2rem)";
          setTimeout(() => {
            this.heroTextScore.style.opacity = "1";
            this.heroTextScore.style.transform = "translateY(0)";
          }, 150);

          this.score = 1;
          this.scoreAccum = 1;
          this.scoreDisplay.textContent = this.formatScore(this.score);
          this.startScoreLoop();
        }
      }

      private formatScore(score: number): string {
        return score.toString().padStart(4, "0");
      }

      private startScoreLoop() {
        this.stopScoreLoop();
        let lastTime = performance.now();
        const loop = (time: number) => {
          const delta = Math.min((time - lastTime) / 1000, 0.1);
          lastTime = time;
          this.scoreAccum += 10 * this.getSpeedMultiplier() * delta;
          const newScore = Math.floor(this.scoreAccum);
          if (newScore > this.score) {
            this.score = newScore;
            this.scoreDisplay.textContent = this.formatScore(this.score);
          }
          this.scoreLoopId = requestAnimationFrame(loop);
        };
        this.scoreLoopId = requestAnimationFrame(loop);
      }

      private stopScoreLoop() {
        if (this.scoreLoopId) {
          cancelAnimationFrame(this.scoreLoopId);
          this.scoreLoopId = null;
        }
      }

      private getSpeedMultiplier(): number {
        return 1 + this.score / 1000;
      }

      private getCurrentEnemySpeed(baseSpeed: number): number {
        return baseSpeed * this.getSpeedMultiplier();
      }

      private getCurrentPlatformScrollSpeed(): number {
        return this.basePlatformScrollSpeed * this.getSpeedMultiplier();
      }

      private getCurrentWalkFPS(): number {
        return this.baseWalkFPS * this.getSpeedMultiplier();
      }

      private getNextSpawnGap(): number {
        const speed = this.getCurrentPlatformScrollSpeed();
        const minTimeSec = Math.max(1.0, 3.0 - this.score / 1000);
        const variationSec = Math.random() * Math.max(0.5, 2.5 - this.score / 2000);
        return (minTimeSec + variationSec) * speed;
      }

      private spawnEnemy() {
        const jumpBlocked = this.score >= 800 && this.score < 1000;
        const rand = Math.random();
        let type: EnemyType;
        if (jumpBlocked) {
          type = rand < 0.5 ? "walk" : "fly";
        } else {
          type = rand < 0.35 ? "walk" : rand < 0.70 ? "jump" : "fly";
        }

        const frames =
          type === "fly"
            ? this.enemy3Frames
            : type === "jump" ? this.enemy2Frames
            : this.enemyFrames;

        if (frames.length === 0) return;

        const isBigFly = type === "fly" && Math.random() < 0.2;
        const isBigWalk = type === "walk" && Math.random() < 0.2;

        const el = document.createElement("div");
        const size = type === "jump" ? 95 : type === "fly" ? (isBigFly ? 200 : 130) : (isBigWalk ? 270 : 90);
        const zIndex = type === "walk" ? 59 : type === "jump" ? 55 : 53;
        el.style.cssText = `position:fixed;width:${size}px;height:${size}px;pointer-events:none;z-index:${zIndex};`;

        const img = document.createElement("img");
        img.className = "txp-sprite";
        img.style.cssText = type === "fly"
          ? "width:100%;height:100%;object-fit:contain;"
          : "width:100%;height:100%;object-fit:contain;transform:scaleX(-1);";
        img.src = frames[0].src;
        el.appendChild(img);

        const platformRect = this.platformContainer.getBoundingClientRect();
        const x = window.innerWidth + 10;
        const yOffset = type === "fly" ? 200 : type === "jump" ? 91 : (isBigWalk ? 260 : 86);
        const y = platformRect.top - yOffset;
        el.style.left = `${x}px`;
        el.style.top = `${y}px`;

        const hitbox = type === "fly"
          ? isBigFly
            ? { x: 20, y: 65, w: 160, h: 60 }
            : { x: 15, y: 30, w: 80, h: 40 }
          : isBigWalk
            ? { x: 30, y: 15, w: 195, h: 240 }
            : this.enemyHitbox;

        if (this.showHitboxes) {
          this.addHitboxOverlay(el, hitbox);
        }

        document.body.appendChild(el);

        const baseSpeed = type === "walk" ? (isBigWalk ? 100 : 200) : type === "jump" ? 130 : (isBigFly ? 170 : 221);
        const speed = this.getCurrentEnemySpeed(baseSpeed);

        const points = type === "walk" ? (isBigWalk ? 30 : 10)
          : type === "jump" ? 20
          : (isBigFly ? 50 : 15);

        this.enemies.push({
          element: el,
          sprite: img,
          x,
          currentFrame: 0,
          lastFrameTime: performance.now(),
          type,
          jumpOffset: 0,
          lastJumpTime: performance.now(),
          speed,
          dying: false,
          baseY: y,
          hitbox,
          floatAmplitude: type === "fly" ? (isBigFly ? 66 : 22) : 0,
          points,
        });
      }

      private startGameLoop() {
        let lastTime = performance.now();

        const loop = (time: number) => {
          if (!this.isRunning || this.isDead || this.isPaused) return;

          const delta = (time - lastTime) / 1000;
          lastTime = time;

          if (this.hasJumpedOnce) {
            this.distanceSinceLastSpawn += this.getCurrentPlatformScrollSpeed() * delta;
            if (this.distanceSinceLastSpawn >= this.nextSpawnGap) {
              this.spawnEnemy();
              this.distanceSinceLastSpawn = 0;
              this.nextSpawnGap = this.getNextSpawnGap();
            }
          }

          this.updateEnemies(delta, time);
          this.checkCollisions();

          this.gameLoopId = requestAnimationFrame(loop);
        };

        this.gameLoopId = requestAnimationFrame(loop);
      }

      private updateEnemies(delta: number, time: number) {
        for (let i = this.enemies.length - 1; i >= 0; i--) {
          const enemy = this.enemies[i];
          if (enemy.dying) continue;

          if (enemy.floatAmplitude === 66) {
            const speedMult = 1 + Math.sin(time * 0.0015) * 0.7;
            enemy.x -= enemy.speed * delta * speedMult;
          } else {
            enemy.x -= enemy.speed * delta;
          }
          enemy.element.style.left = `${enemy.x}px`;

          if (enemy.type === "jump") {
            if (time - enemy.lastJumpTime >= 5000) {
              enemy.lastJumpTime = time;
            }

            const jumpProgress = Math.min((time - enemy.lastJumpTime) / 4800, 1);
            const jumpHeight = 400;
            enemy.jumpOffset = -Math.abs(Math.sin(jumpProgress * Math.PI)) * jumpHeight;
            enemy.element.style.top = `${this.platformContainer.getBoundingClientRect().top - 91 + enemy.jumpOffset}px`;

            const frameInterval = 1000 / ENEMY2_JUMP.fps;
            if (time - enemy.lastFrameTime >= frameInterval) {
              enemy.currentFrame = (enemy.currentFrame + 1) % this.enemy2Frames.length;
              enemy.sprite.src = this.enemy2Frames[enemy.currentFrame].src;
              enemy.lastFrameTime = time;
            }
          } else if (enemy.type === "fly") {
            const sinVal = Math.sin(time * 0.002);
            const floatOffset = enemy.floatAmplitude === 66
              ? sinVal * (sinVal > 0 ? 22 : 66)
              : sinVal * enemy.floatAmplitude;
            enemy.element.style.top = `${enemy.baseY + floatOffset}px`;

            const flyFrames = this.enemy3Frames;

            const frameInterval = 1000 / ENEMY3_FLY.fps;
            if (time - enemy.lastFrameTime >= frameInterval) {
              enemy.currentFrame = (enemy.currentFrame + 1) % flyFrames.length;
              enemy.sprite.src = flyFrames[enemy.currentFrame].src;
              enemy.lastFrameTime = time;
            }
          } else {
            const frameInterval = 1000 / ENEMY_WALK.fps;
            if (time - enemy.lastFrameTime >= frameInterval) {
              enemy.currentFrame = (enemy.currentFrame + 1) % this.enemyFrames.length;
              enemy.sprite.src = this.enemyFrames[enemy.currentFrame].src;
              enemy.lastFrameTime = time;
            }
          }

          if (enemy.x < -100) {
            enemy.element.remove();
            this.enemies.splice(i, 1);
          }
        }
      }

      private checkCollisions() {
        for (let i = this.enemies.length - 1; i >= 0; i--) {
          const enemy = this.enemies[i];
          if (!enemy.dying && this.isColliding(enemy)) {
            if (this.isStompingOn(enemy)) {
              this.killEnemy(enemy, i);
            } else {
              this.die();
              return;
            }
          }
        }
      }

      private isColliding(enemy: EnemyInstance): boolean {
        const txpRect = this.character.getBoundingClientRect();
        const enemyRect = enemy.element.getBoundingClientRect();

        const txpBox = {
          left: txpRect.left + this.txpHitbox.x,
          top: txpRect.top + this.txpHitbox.y,
          right: txpRect.left + this.txpHitbox.x + this.txpHitbox.w,
          bottom: txpRect.top + this.txpHitbox.y + this.txpHitbox.h,
        };

        const enemyBox = {
          left: enemyRect.left + enemy.hitbox.x,
          top: enemyRect.top + enemy.hitbox.y,
          right: enemyRect.left + enemy.hitbox.x + enemy.hitbox.w,
          bottom: enemyRect.top + enemy.hitbox.y + enemy.hitbox.h,
        };

        return txpBox.left < enemyBox.right &&
          txpBox.right > enemyBox.left &&
          txpBox.top < enemyBox.bottom &&
          txpBox.bottom > enemyBox.top;
      }

      private isStompingOn(enemy: EnemyInstance): boolean {
        if (!this.isJumping) return false;

        const txpRect = this.character.getBoundingClientRect();
        const enemyRect = enemy.element.getBoundingClientRect();

        const txpBottom = txpRect.top + this.txpHitbox.y + this.txpHitbox.h;
        const enemyTop = enemyRect.top + enemy.hitbox.y;
        const enemyHeight = enemy.hitbox.h;

        return txpBottom < enemyTop + enemyHeight * 0.4;
      }

      private showScorePopup(x: number, y: number, points: number) {
        const popup = document.createElement("div");
        popup.textContent = `+${points}P`;
        popup.style.cssText = `position:fixed;left:${x}px;top:${y}px;transform:translateX(-50%);font-size:1.1rem;font-weight:700;color:var(--color-fg);pointer-events:none;z-index:65;white-space:nowrap;letter-spacing:0.08em;transition:transform 0.65s ease-out,opacity 0.65s ease-out;`;
        document.body.appendChild(popup);
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            popup.style.transform = "translateX(-50%) translateY(-56px)";
            popup.style.opacity = "0";
          });
        });
        setTimeout(() => popup.remove(), 700);
      }

      private killEnemy(enemy: EnemyInstance, index: number) {
        enemy.dying = true;
        enemy.speed = 0;

        const el = enemy.element;
        const enemyRect = el.getBoundingClientRect();
        el.style.transition = "transform 0.3s ease-out, opacity 0.3s ease-out";
        el.style.transformOrigin = "bottom center";
        el.style.transform = "scaleY(0.15) scaleX(1.4)";
        el.style.opacity = "0";

        const bonus = enemy.points;
        this.showScorePopup(enemyRect.left + enemyRect.width / 2, enemyRect.top + enemyRect.height / 3, bonus);

        setTimeout(() => {
          el.remove();
          const idx = this.enemies.indexOf(enemy);
          if (idx !== -1) this.enemies.splice(idx, 1);
        }, 300);

        this.score += bonus;
        this.scoreAccum += bonus;
        this.scoreDisplay.textContent = this.formatScore(this.score);

        if (this.isJumping) {
          this.hasUsedSpaceDoubleJump = false;
          this.startDoubleJump();
        }
      }

      private die() {
        this.isDead = true;
        this.isJumping = false;
        this.isDoubleJumping = false;
        this.hasUsedSpaceDoubleJump = false;
        this.character.style.transform = "";

        this.stopScoreLoop();
        if (this.gameLoopId) {
          cancelAnimationFrame(this.gameLoopId);
          this.gameLoopId = null;
        }

        this.deathScoreDisplay.textContent = this.formatScore(this.score);

        if (this.score > this.highscore) {
          this.highscore = this.score;
          localStorage.setItem("txpHighscore", String(this.highscore));
          this.highscoreDisplay.textContent = "Neuer Highscore";
          this.highscoreDisplay.style.opacity = "1";
        } else {
          this.highscoreDisplay.textContent = `Highscore \u00A0 ${this.formatScore(this.highscore)}`;
          this.highscoreDisplay.style.opacity = "0.5";
        }

        this.deathScreen.style.opacity = "1";
        this.deathScreen.style.pointerEvents = "auto";
      }

      private restart() {
        this.isDead = false;
        this.isPaused = false;
        this.isJumping = false;
        this.isDoubleJumping = false;
        this.hasUsedSpaceDoubleJump = false;
        this.currentJumpProgress = 0;
        this.currentOffsetY = 0;
        this.jumpTotalPausedTime = 0;
        this.doubleJumpTotalPausedTime = 0;
        this.character.style.transform = "";

        this.deathScreen.style.opacity = "0";
        this.deathScreen.style.pointerEvents = "none";
        this.pauseScreen.style.opacity = "0";
        this.pauseScreen.style.pointerEvents = "none";

        this.clearEnemies();

        this.score = 1;
        this.scoreAccum = 1;
        this.scoreDisplay.textContent = this.formatScore(this.score);
        this.startScoreLoop();

        const walkFrames = this.cachedAnimations.get("walk");
        if (walkFrames) {
          this.playAnimation(walkFrames, this.baseWalkFPS, true, 12);
        }

        this.distanceSinceLastSpawn = 0;
        this.nextSpawnGap = this.getNextSpawnGap();
        this.startGameLoop();
      }

      private clearEnemies() {
        for (const enemy of this.enemies) {
          enemy.element.remove();
        }
        this.enemies = [];
      }

      private pause() {
        if (this.isPaused || this.isDead || !this.hasJumpedOnce) return;
        this.isPaused = true;

        this.stopScoreLoop();

        if (this.gameLoopId) {
          cancelAnimationFrame(this.gameLoopId);
          this.gameLoopId = null;
        }

        if (this.runnerAnimationId) {
          cancelAnimationFrame(this.runnerAnimationId);
          this.runnerAnimationId = null;
        }

        this.pauseScreen.style.opacity = "1";
        this.pauseScreen.style.pointerEvents = "auto";
      }

      private resume() {
        if (!this.isPaused) return;
        this.isPaused = false;

        this.pauseScreen.style.opacity = "0";
        this.pauseScreen.style.pointerEvents = "none";

        this.startScoreLoop();

        let lastTime = performance.now();

        const animateLeft = (time: number) => {
          if (!this.isActive || !this.isRunning || this.isPaused) return;

          const delta = (time - lastTime) / 1000;
          lastTime = time;

          const scrollSpeed = this.getCurrentPlatformScrollSpeed();
          this.totalLeftExtension += scrollSpeed * delta;

          const additionalScale = this.totalLeftExtension / this.platformStartWidth;
          const totalScale = this.scaleAfterPhase1 + additionalScale;

          this.platform.style.transform = `translateX(-${this.totalLeftExtension}px) scaleX(${totalScale})`;

          this.runnerAnimationId = requestAnimationFrame(animateLeft);
        };

        this.runnerAnimationId = requestAnimationFrame(animateLeft);

        this.distanceSinceLastSpawn = 0;
        this.nextSpawnGap = this.getNextSpawnGap();
        this.startGameLoop();
      }

      private toggleHitboxes() {
        this.showHitboxes = !this.showHitboxes;

        if (this.showHitboxes) {
          if (!this.txpHitboxEl) {
            this.txpHitboxEl = this.addHitboxOverlay(this.character, this.txpHitbox);
          }
          this.txpHitboxEl.style.display = "block";
          for (const enemy of this.enemies) {
            if (!enemy.element.querySelector(".txp-hitbox")) {
              this.addHitboxOverlay(enemy.element, enemy.hitbox);
            }
          }
        } else {
          if (this.txpHitboxEl) {
            this.txpHitboxEl.style.display = "none";
          }
          for (const enemy of this.enemies) {
            const hb = enemy.element.querySelector(".txp-hitbox") as HTMLElement;
            if (hb) hb.style.display = "none";
          }
        }
      }

      private addHitboxOverlay(parent: HTMLElement, hitbox: { x: number; y: number; w: number; h: number }): HTMLDivElement {
        const overlay = document.createElement("div");
        overlay.className = "txp-hitbox";
        overlay.style.cssText = `position:absolute;left:${hitbox.x}px;top:${hitbox.y}px;width:${hitbox.w}px;height:${hitbox.h}px;border:1.5px solid var(--color-fg);opacity:0.4;pointer-events:none;box-sizing:border-box;`;
        parent.appendChild(overlay);
        return overlay;
      }

      private async talk() {
        if (this.textState >= 4) return;

        this.playTalkAnimation();

        if (this.textState === 1) {
          this.heroTextTXP.style.opacity = "0";
          this.heroTextTXP.style.transform = "translateY(-2rem)";
          setTimeout(() => {
            this.heroTextFinal.style.opacity = "1";
            this.heroTextFinal.style.transform = "translateY(0)";
          }, 150);
          this.textState = 2;
        } else if (this.textState === 2) {
          this.heroTextFinal.style.opacity = "0";
          this.heroTextFinal.style.transform = "translateY(-2rem)";
          setTimeout(() => {
            this.heroTextWelcome.style.opacity = "1";
            this.heroTextWelcome.style.transform = "translateY(0)";
          }, 150);
          this.textState = 3;
        } else if (this.textState === 3) {
          this.heroTextWelcome.style.opacity = "0";
          this.heroTextWelcome.style.transform = "translateY(-2rem)";
          setTimeout(() => {
            this.heroTextThanks.style.opacity = "1";
            this.heroTextThanks.style.transform = "translateY(0)";
          }, 150);
          this.textState = 4;
        }
      }

      private async playTalkAnimation() {
        let talkFrames = this.cachedAnimations.get("talk");
        if (!talkFrames) {
          talkFrames = await preloadAnimation("talk");
          this.cachedAnimations.set("talk", talkFrames);
        }

        await this.playAnimation(talkFrames, 24, false);
        await this.playAnimation(talkFrames, 24, false);

        let idleFrames = this.cachedAnimations.get("idle");
        if (!idleFrames) {
          idleFrames = await preloadAnimation("idle");
          this.cachedAnimations.set("idle", idleFrames);
        }
        if (this.isActive) {
          this.playAnimation(idleFrames, 24, true);
        }
      }

      private updatePosition() {
        const platformRect = this.platformContainer.getBoundingClientRect();
        const targetX = platformRect.left + platformRect.width / 2 - 45;
        const targetY = platformRect.top - 86;
        this.character.style.left = `${targetX}px`;
        this.character.style.top = `${targetY}px`;
      }

      private playAnimation(frames: HTMLImageElement[], baseFPS: number, loop: boolean, startFrame: number = 0): Promise<void> {
        return new Promise((resolve) => {
          this.currentFrames = frames;
          this.currentFrame = startFrame;
          this.fps = baseFPS;
          this.lastFrameTime = performance.now();

          if (this.animationId) {
            cancelAnimationFrame(this.animationId);
          }

          let pauseStartTime = 0;
          const isWalkAnimation = frames === this.cachedAnimations.get("walk");

          const animate = (time: number) => {
            if (!this.isActive) {
              resolve();
              return;
            }

            if (this.isPaused) {
              if (pauseStartTime === 0) {
                pauseStartTime = time;
              }
              this.animationId = requestAnimationFrame(animate);
              return;
            } else if (pauseStartTime > 0) {
              const pauseDuration = time - pauseStartTime;
              this.lastFrameTime += pauseDuration;
              pauseStartTime = 0;
            }

            const currentFPS = isWalkAnimation && this.isRunning ? this.getCurrentWalkFPS() : baseFPS;
            const elapsed = time - this.lastFrameTime;
            const frameInterval = 1000 / currentFPS;

            if (elapsed >= frameInterval) {
              if (isWalkAnimation && this.isRunning) {
                const framesToAdvance = Math.max(1, Math.floor(elapsed / frameInterval));
                this.currentFrame = (this.currentFrame + framesToAdvance) % this.currentFrames.length;
                this.sprite.src = this.currentFrames[this.currentFrame].src;
              } else {
                this.sprite.src = this.currentFrames[this.currentFrame].src;
                this.currentFrame++;

                if (this.currentFrame >= this.currentFrames.length) {
                  if (loop) {
                    this.currentFrame = 0;
                  } else {
                    resolve();
                    return;
                  }
                }
              }

              this.lastFrameTime = time - (elapsed % frameInterval);
            }

            this.animationId = requestAnimationFrame(animate);
          };

          this.animationId = requestAnimationFrame(animate);
        });
      }
    }

    new TXPAnimator();
  </script>
</BaseLayout>
